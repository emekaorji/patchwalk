{
    "name": "patchwalk",
    "displayName": "Patchwalk",
    "version": "0.1.1",
    "description": "Narrate your codebase in natural language. Works with any agent that supports MCP.",
    "publisher": "coderabbi",
    "private": true,
    "preview": false,
    "author": {
        "name": "emekaorji",
        "email": "emekapraiseo@gmail.com",
        "url": "https://github.com/emekaorji"
    },
    "license": "MIT",
    "homepage": "https://github.com/emekaorji/patchwalk#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/emekaorji/patchwalk.git"
    },
    "bugs": {
        "url": "https://github.com/emekaorji/patchwalk/issues",
        "email": "emekapraiseo@gmail.com"
    },
    "keywords": [
        "ai",
        "agent",
        "mcp",
        "voice",
        "narration",
        "text-to-speech",
        "code-review",
        "walkthrough",
        "onboarding",
        "claude",
        "codex",
        "copilot",
        "explain-code",
        "accessibility"
    ],
    "categories": [
        "AI",
        "Education",
        "Visualization",
        "Other"
    ],
    "main": "./out/src/extension/index.js",
    "icon": "assets/logo.png",
    "packageManager": "pnpm@9.9.0",
    "engines": {
        "vscode": "^1.90.0"
    },
    "badges": [
        {
            "url": "https://img.shields.io/badge/PRs-welcome-brightgreen.svg",
            "description": "PRs Welcome",
            "href": "https://github.com/emekaorji/patchwalk/fork"
        }
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "commands": [
            {
                "command": "patchwalk.restartDaemon",
                "title": "Patchwalk: Restart Daemon"
            },
            {
                "command": "patchwalk.showDaemonStatus",
                "title": "Patchwalk: Show Daemon Status"
            },
            {
                "command": "patchwalk.stopDaemon",
                "title": "Patchwalk: Stop Daemon"
            },
            {
                "command": "patchwalk.playFromClipboard",
                "title": "Patchwalk: Play Walk From Clipboard"
            },
            {
                "command": "patchwalk.revealPlayingWindow",
                "title": "Patchwalk: Reveal Playing Window"
            },
            {
                "command": "patchwalk.copyMcpEndpoint",
                "title": "Patchwalk: Copy MCP Endpoint"
            },
            {
                "command": "patchwalk.connectAgents",
                "title": "Patchwalk: Connect My Agents"
            }
        ],
        "configuration": {
            "title": "Patchwalk",
            "properties": {
                "patchwalk.daemonPort": {
                    "type": "number",
                    "default": 7357,
                    "minimum": 1,
                    "maximum": 65535,
                    "description": "Local TCP port used by the Patchwalk daemon MCP HTTP endpoint."
                },
                "patchwalk.voice": {
                    "type": "string",
                    "default": "system",
                    "description": "Active Patchwalk narration voice. \"system\" uses the OS voice (macOS say / Windows SAPI / Linux espeak-ng). Set to a downloaded neural voice id, managed from the Patchwalk sidebar."
                },
                "patchwalk.overviewEditor": {
                    "type": "boolean",
                    "default": true,
                    "description": "Open a Patchwalk overview editor beside your code when a walk starts, showing the agenda and stats of everything about to be explained."
                },
                "patchwalk.autoRevealSidebar": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically reveal the Patchwalk sidebar in the window that is playing a walk, so it is obvious which window is being controlled."
                },
                "patchwalk.tintWindowDuringPlayback": {
                    "type": "boolean",
                    "default": false,
                    "description": "While a walk plays, tint this window's title bar, activity bar, and status bar so it stands out among many open windows. This writes workbench.colorCustomizations to the workspace settings (.vscode/settings.json in a single-folder project) and restores them when the walk ends."
                },
                "patchwalk.narrationStyle": {
                    "type": "string",
                    "enum": [
                        "terse",
                        "grounded"
                    ],
                    "enumDescriptions": [
                        "Dense, high-signal lines. The listener hears the point and gets their time back.",
                        "Longer, more explanatory narration. Better for onboarding or unfamiliar code."
                    ],
                    "default": "terse",
                    "scope": "application",
                    "markdownDescription": "How much the authoring agent is allowed to say. This rewrites the instructions and the tool schema the Patchwalk daemon hands to agents, and one daemon serves every window — so it is **global only** and cannot be set per-workspace."
                },
                "patchwalk.pacing.stepGapMs": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "maximum": 5000,
                    "markdownDescription": "Extra silence (ms) before a new step is spoken. Defaults to `0` — the walk should sound like one continuous passage. Raise it only if you want a deliberate beat between steps."
                },
                "patchwalk.pacing.subSegmentGapMs": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "maximum": 5000,
                    "markdownDescription": "Extra silence (ms) between sub-segments inside a step. Defaults to `0` so the highlight moves without breaking the sentence."
                },
                "patchwalk.systemVoice": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Which OS voice narrates a walk (e.g. `Samantha`, `Daniel`). Leave empty to use your OS default voice, which is usually the most natural-sounding one. Note that compact voices synthesize faster but sound robotic. List voices with `say -v '?'` on macOS."
                },
                "patchwalk.prefetchAudio": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Pre-render each line's audio while the previous one is still playing. This is what removes the multi-second pause between segments. Turn it **off** to fall back to the simplest path (speak each line live) if you hit any audio trouble."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "patchwalk",
                    "title": "Patchwalk",
                    "icon": "assets/patchwalk-activitybar.svg"
                }
            ]
        },
        "views": {
            "patchwalk": [
                {
                    "id": "patchwalk.walkMonitor",
                    "type": "webview",
                    "name": "Walk Monitor",
                    "icon": "assets/patchwalk-activitybar.svg"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "patchwalk.walkMonitor",
                "contents": "No walk has played yet.\n\nPatchwalk speaks a change out loud when your AI agent asks it to. Point your agent at the local Patchwalk daemon, then ask it to walk you through a change.\n\n[Copy MCP endpoint](command:patchwalk.copyMcpEndpoint)\n[Setup guide](https://github.com/emekaorji/patchwalk#readme)\n\nYou can also try it right now with a walk payload on your clipboard:\n[Play walk from clipboard](command:patchwalk.playFromClipboard)"
            }
        ]
    },
    "eslintConfig": {
        "extends": "@yutengjing/eslint-config-typescript",
        "ignorePatterns": [
            "test-workspace*"
        ],
        "rules": {
            "no-void": "off",
            "jsdoc/no-undefined-types": "off"
        }
    },
    "prettier": "@yutengjing/prettier-config",
    "lint-staged": {
        "{src,test,scripts}/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "**/*.{json,md}": [
            "prettier --write"
        ]
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "scripts": {
        "vscode:prepublish": "pnpm esbuild:base --minify",
        "preinstall": "npx only-allow pnpm",
        "postinstall": "stale-dep -u",
        "prepare": "simple-git-hooks",
        "clean": "npx rimraf -rf ./out",
        "clean:test": "npx rimraf -rf ./out/test",
        "esbuild:base": "stale-dep && tsx scripts/esbuild.ts",
        "esbuild:watch": "pnpm esbuild:base --sourcemap --watch",
        "esbuild:analyze": "pnpm esbuild:base --minify --metafile --analyze && esbuild-visualizer --metadata ./meta.json --open",
        "compile:test": "pnpm clean:test && tsc -b ./test/tsconfig.json",
        "lint": "eslint src test scripts --ext ts",
        "play:sample": "tsx scripts/send-sample-walk.ts",
        "test": "pnpm esbuild:base && pnpm compile:test && node ./out/test/runTests.js",
        "package": "vsce package --no-dependencies",
        "release": "npx @yutengjing/release",
        "publish:vs-marketplace": "vsce publish --no-dependencies",
        "publish:open-vsx": "ovsx publish --no-dependencies"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.7",
        "@types/node": "~20.16.2",
        "@types/vscode": "1.90.0",
        "@types/ws": "^8.18.1",
        "@vscode/test-electron": "^2.4.1",
        "@vscode/vsce": "^3.0.0",
        "@yutengjing/eslint-config-typescript": "^1.2.2",
        "@yutengjing/prettier-config": "^1.3.0",
        "@yutengjing/release": "^0.3.1",
        "esbuild": "~0.23.1",
        "esbuild-visualizer": "^0.6.0",
        "eslint": "^8.57.0",
        "glob": "^11.0.0",
        "lint-staged": "^15.2.9",
        "mocha": "^10.7.3",
        "ovsx": "^0.9.2",
        "prettier": "^3.3.3",
        "rimraf": "^6.0.1",
        "simple-git-hooks": "^2.11.1",
        "stale-dep": "^0.7.0",
        "tsx": "^4.19.0",
        "typescript": "~5.5.4"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "jsonc-parser": "^3.3.1",
        "ws": "^8.19.0",
        "yaml": "^2.9.0",
        "zod": "^4.3.6"
    },
    "galleryBanner": {
        "color": "#161B24",
        "theme": "dark"
    },
    "qna": "marketplace"
}
