{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
        },
        "specVersion": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
        },
        "handoffId": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "producer": {
            "type": "object",
            "properties": {
                "agent": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                },
                "agentVersion": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                },
                "model": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                }
            },
            "required": ["agent"],
            "additionalProperties": false
        },
        "summary": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
        },
        "walkthrough": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "\\S"
                    },
                    "title": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "\\S"
                    },
                    "narration": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "\\S"
                    },
                    "path": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "\\S"
                    },
                    "type": {
                        "type": "string",
                        "enum": ["symbol", "range", "line"]
                    },
                    "symbol": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "\\S"
                    },
                    "range": {
                        "type": "object",
                        "properties": {
                            "startLine": {
                                "type": "integer",
                                "minimum": 1,
                                "maximum": 9007199254740991
                            },
                            "endLine": {
                                "type": "integer",
                                "minimum": 1,
                                "maximum": 9007199254740991
                            }
                        },
                        "required": ["startLine", "endLine"],
                        "additionalProperties": false
                    }
                },
                "required": ["id", "title", "narration", "path", "range"],
                "additionalProperties": false
            }
        }
    },
    "required": ["specVersion", "handoffId", "createdAt", "producer", "summary", "walkthrough"],
    "additionalProperties": false,
    "$id": "https://patchwalk.dev/schema/handoff-1.0.schema.json",
    "title": "Patchwalk handoff payload"
}
