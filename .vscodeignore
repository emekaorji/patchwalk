# Deny-all under out/, then allow ONLY the two esbuild bundles the runtime actually loads.
# `compile:test` also emits tsc output into out/, and without this allowlist it silently ships
# ~300 KB of dead, unreachable modules alongside the bundles.
out/**
!out/src/extension/index.js
!out/src/daemon/index.js

# source + build tooling
src
scripts
test
test-workspace-primary
test-workspace-secondary
.vscode-test
tsconfig.*
.eslintrc*
.prettier*
.editorconfig

# assets: ship only what the manifest references
assets
!assets/logo.png
!assets/patchwalk-activitybar.svg

# repo/dev files
.github
.vscode
.gitignore
.gitattributes
.nvmrc
.npmrc
pnpm-lock.yaml
package-lock.json

# dev-only docs and local/agent scratch (never shipped)
# NOTE: `dir` alone does not exclude `dir/file` — `*` never crosses a `/`. Always use `dir/**`.
PLAN.md
BUILD_PROGRESS.md
_local
_local/**
.codex
.codex/**
.claude
.claude/**

# local artifacts
*.vsix
*.handoff.json
meta.json
stats.html
